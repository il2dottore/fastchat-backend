# Optional path to an alternative env file.
# DOTENV_CONFIG_PATH=src/.env

# Application
JWT_SECRET=replace-with-a-long-random-secret
HOST=0.0.0.0
PORT=443
HTTPS_ENABLED=true
HTTPS_KEY_PATH=certs/key.pem
HTTPS_CERT_PATH=certs/cert.pem

# MongoDB
MONGO_DB_HOST=localhost
MONGO_DB_PORT=27017
MONGO_DB_USERNAME=your-mongodb-username
MONGO_DB_PASSWORD=your-mongodb-password
MONGO_DB_DATABASE=sussychat

# Gmail SMTP (use a Gmail app password)
MAIL_USER=your-email@example.com
MAIL_PASS=your-gmail-app-password

# Cloudflare R2 / S3-compatible object storage
R2_BUCKET=your-bucket
R2_PUBLIC_URL=https://cdn.example.com
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key

# Coturn
TURN_REALM=sussychat.local
TURN_EXTERNAL_IP=your-server-public-ip
TURN_USERNAME=your-turn-username
TURN_PASSWORD=your-turn-password
TURN_TLS_ENABLED=false

# Docker Compose overrides (optional)
# APP_PORT=443
# MONGO_PORT_FORWARD=27017
