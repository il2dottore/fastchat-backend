@startuml
title Quy trình: Gửi tin nhắn trực tiếp (DM)

start
:Người dùng mở cuộc trò chuyện 1-1;

if (Kiểm tra trạng thái Block?) then (Bị Block (1 trong 2 bên))
  :Vô hiệu hóa khung nhập liệu;
  :Hiển thị thông báo "Không thể gửi tin nhắn";
  stop
else (Không bị Block)
  :Người dùng nhập tin nhắn và nhấn "Gửi";
  
  if (Có tệp đính kèm?) then (Có)
    :Tải tệp lên Server;
    :Lấy thông tin Media;
  endif
  
  :Gửi 'createMessage' qua Socket;
  
  :Backend lưu tin nhắn vào Database;
  :Cập nhật trạng thái 'Tin nhắn cuối' (Last message);
  
  :Broadcasting tới thiết bị của đối phương;
  :Gửi Push Notification (FCM);
  :Hiển thị tin nhắn trên màn hình cả hai;
endif

stop
@enduml